{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capabilities for the 学道 desktop shell (splash + loopback main window).",
  "windows": ["splash", "main"],
  "permissions": [
    "core:default",
    "updater:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/uh-backend",
          "sidecar": true,
          "args": true
        }
      ]
    }
  ]
}
