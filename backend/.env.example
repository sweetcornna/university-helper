# Database
MAIN_DB_HOST=localhost
MAIN_DB_NAME=main_db
MAIN_DB_USER=postgres
MAIN_DB_PASSWORD=postgres
MAIN_DB_PORT=5432

# JWT
# SECRET_KEY: required. Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# Third-party credential at-rest encryption (urlsafe-base64 Fernet key).
# CREDENTIAL_ENCRYPTION_KEY: required in production (ENV=production / APP_ENV=production).
# In dev, a missing key falls back to plaintext storage with a loud warning.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=

# Optional legacy compatibility token for the shuake client.
# SHUAKE_COMPAT_SECRET: leave empty to disable. If set, MUST be >= 32 chars.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SHUAKE_COMPAT_SECRET=
