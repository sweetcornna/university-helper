# Deployment env for docker-compose.server.yml
#
# Copy to .env and fill in real values before `make start`. Never commit
# the resulting .env (it's in .gitignore).

# --- Database ---
POSTGRES_PASSWORD=change-this-db-password

# --- App / API ---
SECRET_KEY=change-this-jwt-secret-key-min-32-characters
# When set, /api/v1/auth/shuake-token issues a 7-day compat token. Min 32 chars.
SHUAKE_COMPAT_SECRET=
# Origins allowed to call the API with cookies/Authorization. Must NOT be "*"
# when ENV=production; HTTPS-only is enforced unless the host is localhost.
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
APP_PORT=8000
NGINX_PORT=80
# Tag your environment: "production" enables strict CORS/HTTPS guards.
ENV=production

# --- Crypto ---
# Third-party credential at-rest encryption (urlsafe-base64 Fernet key).
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Required in production (ENV=production); in dev a missing key falls back to
# plaintext storage with a loud warning.
CREDENTIAL_ENCRYPTION_KEY=

# --- Optional knobs ---
# BCRYPT_ROUNDS=12          # clamped 4..15 by app/core/security.py
# ACCESS_TOKEN_EXPIRE_MINUTES=30
# LOG_LEVEL=INFO            # DEBUG, INFO, WARNING, ERROR
# LOG_FORMAT=json           # plain (default) or json (one-line per record)
# DOCS_ENABLED=false        # set true to expose /docs and /openapi.json
# BAIDU_MAP_API_KEY=        # opt-in: Baidu Maps API for the location picker

# --- Backups (scripts/db_backup.sh) ---
# AGE_RECIPIENT=age1...     # encrypt dumps for this recipient
# AGE_RECIPIENT_FILE=/etc/uh/age-recipients.txt
# RETAIN_DAYS=14            # how long to keep encrypted dumps locally
